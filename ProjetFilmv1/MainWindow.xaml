<Window x:Class="ProjetFilmv1.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:models="clr-namespace:ProjetFilmv1.Models"
        Title="FILMATRON 2000"
        Width="1200"
        Height="800"
        MinWidth="360"
        MinHeight="640"
        WindowStartupLocation="CenterScreen">
    <Grid Background="{DynamicResource AppBackgroundBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <DockPanel Grid.Row="0" LastChildFill="False">
            <DockPanel.Resources>
                <Style x:Key="TopButtonStyle" TargetType="Button">
                    <Setter Property="Background" Value="Transparent" />
                    <Setter Property="Foreground" Value="White" />
                    <Setter Property="BorderThickness" Value="0" />
                    <Setter Property="Padding" Value="10,6" />
                    <Setter Property="FontSize" Value="14" />
                    <Setter Property="Cursor" Value="Hand" />
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="bd" Background="{TemplateBinding Background}" CornerRadius="8" Padding="{TemplateBinding Padding}">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="bd" Property="Background" Value="#20FFFFFF"/>
                                    </Trigger>
                                    <Trigger Property="IsPressed" Value="True">
                                        <Setter TargetName="bd" Property="Background" Value="#30FFFFFF"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>

                <Style x:Key="FeaturedNavButtonStyle" TargetType="Button" BasedOn="{StaticResource TopButtonStyle}">
                    <Setter Property="Background" Value="{DynamicResource AccentBrush}" />
                    <Setter Property="Padding" Value="16,10" />
                    <Setter Property="FontSize" Value="15" />
                </Style>
            </DockPanel.Resources>

            <Border Background="{DynamicResource NavBackgroundBrush}" DockPanel.Dock="Top" MinHeight="60" Padding="0,8">
                <Border.Effect>
                    <DropShadowEffect Color="#000000" BlurRadius="8" ShadowDepth="1" Opacity="0.12"/>
                </Border.Effect>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="14,0" Grid.Column="0">
                        <Border Width="36" Height="36" CornerRadius="18">
                            <Border.Background>
                                <ImageBrush ImageSource="Images/Logo.png" Stretch="UniformToFill"/>
                            </Border.Background>
                        </Border>
                        <TextBlock Text="FILMATRON 2000" Foreground="White" FontWeight="SemiBold" FontSize="16" VerticalAlignment="Center" Margin="10,0,0,0"/>
                    </StackPanel>

                    <WrapPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center" Grid.Column="1" Margin="12,4">
                        <Button Style="{StaticResource FeaturedNavButtonStyle}" Click="Accueil_Click" Margin="4,0">
                            <TextBlock Text="Voir les films" FontWeight="Bold" Foreground="White"/>
                        </Button>
                    </WrapPanel>

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center" Grid.Column="2" Margin="0,0,14,0">
                        <Button x:Name="AuthButton"
                                Style="{StaticResource TopButtonStyle}"
                                Click="Auth_Click"
                                Margin="0,0,8,0">
                            Connexion / Inscription
                        </Button>

                        <Button x:Name="ProfileButton" Width="36" Height="36" Background="#1F2937" BorderThickness="0" Click="ProfileButton_Click" Visibility="Collapsed">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border CornerRadius="18" Background="{TemplateBinding Background}">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Button.Template>
                            <TextBlock Text="P" Foreground="White" FontWeight="Bold"/>
                            <Button.ContextMenu>
                                <ContextMenu>
                                    <MenuItem Header="Profil" Click="ProfileMenu_Profil_Click" />
                                    <MenuItem Header="Parametres" Click="ProfileMenu_Settings_Click" />
                                    <Separator />
                                    <MenuItem Header="Deconnexion" Click="ProfileMenu_Logout_Click" />
                                </ContextMenu>
                            </Button.ContextMenu>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>
        </DockPanel>

        <Grid x:Name="SearchArea" Grid.Row="1" Margin="12,10">
            <StackPanel Orientation="Vertical" HorizontalAlignment="Stretch">
                <Grid HorizontalAlignment="Center" Width="Auto" MaxWidth="920" MinWidth="620">
                    <Border x:Name="SearchContainer"
                            CornerRadius="28"
                            BorderBrush="{DynamicResource InputBorderBrush}"
                            BorderThickness="1"
                            Background="{DynamicResource SurfaceBrush}"
                            Padding="12"
                            MinHeight="62"
                            HorizontalAlignment="Stretch">
                        <Border.Effect>
                            <DropShadowEffect Color="#000000" BlurRadius="16" ShadowDepth="0" Opacity="0.08" />
                        </Border.Effect>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <Border Width="38" Height="38" CornerRadius="19" Background="{DynamicResource AccentSoftBrush}" VerticalAlignment="Center" Margin="2,0,10,0">
                                <Viewbox Width="18" Height="18" VerticalAlignment="Center" HorizontalAlignment="Center" Opacity="0.9">
                                    <Canvas Width="24" Height="24">
                                        <Path Data="M15.5,14h-0.8l-0.3-0.3a6.5,6.5 0 1 0-1,1l0.3,0.3v0.8L20,20.5 21.5,19 15.5,14z M10,15a5,5 0 1 1 0-10 5,5 0 0 1 0,10z"
                                              Fill="#7D5FFF"
                                              Stretch="Uniform" />
                                    </Canvas>
                                </Viewbox>
                            </Border>

                            <TextBox x:Name="SearchBox"
                                     Grid.Column="1"
                                     Background="Transparent"
                                     BorderThickness="0"
                                     VerticalContentAlignment="Center"
                                     FontSize="16"
                                     Padding="6,0"
                                     TextChanged="SearchBox_TextChanged"
                                     KeyDown="SearchBox_KeyDown"
                                     ToolTip="Rechercher un film..." />

                            <Button Grid.Column="2"
                                    Content="Rechercher"
                                    Click="Search_Click"
                                    VerticalAlignment="Center"
                                    Margin="8,0,0,0"
                                    Padding="18,10"
                                    Cursor="Hand"
                                    Background="{DynamicResource AccentBrush}"
                                    Foreground="White"
                                    BorderThickness="0"
                                    FontWeight="SemiBold" />
                        </Grid>
                    </Border>
                </Grid>

                <Border x:Name="SuggestionsBorder"
                        Width="{Binding ElementName=SearchContainer, Path=ActualWidth}"
                        MaxWidth="920"
                        CornerRadius="16"
                        Margin="0,8,0,0"
                        BorderBrush="{DynamicResource BorderBrush}"
                        BorderThickness="1"
                        Background="{DynamicResource SurfaceBrush}"
                        Visibility="Collapsed"
                        Opacity="0">
                    <Border.Effect>
                        <DropShadowEffect Color="#000000" BlurRadius="16" ShadowDepth="0" Opacity="0.08" />
                    </Border.Effect>
                    <Border.RenderTransform>
                        <TranslateTransform Y="-6" />
                    </Border.RenderTransform>
                    <ListBox x:Name="SearchSuggestions"
                             MaxHeight="260"
                             ScrollViewer.VerticalScrollBarVisibility="Auto"
                             MouseDoubleClick="SearchSuggestions_MouseDoubleClick"
                             BorderThickness="0"
                             Padding="8"
                             Background="Transparent">
                        <ListBox.ItemTemplate>
                            <DataTemplate DataType="{x:Type models:SuggestionItem}">
                                <Border Padding="6" CornerRadius="8" Background="Transparent">
                                    <StackPanel Orientation="Horizontal" Margin="0,4">
                                        <Border Width="40" Height="60" CornerRadius="6" ClipToBounds="True" Background="#EEE">
                                            <Image Source="{Binding PosterImage}" Stretch="UniformToFill" />
                                        </Border>
                                        <StackPanel Orientation="Vertical" Margin="12,0,0,0" MaxWidth="640">
                                            <TextBlock Text="{Binding Title}" FontWeight="Bold" FontSize="14" Foreground="{DynamicResource TextBrush}" />
                                            <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                                                <TextBlock Text="★" Foreground="{DynamicResource AccentBrush}" FontSize="12" Margin="0,0,6,0" />
                                                <TextBlock Text="{Binding Rating}" FontSize="12" Foreground="{DynamicResource SecondaryTextBrush}" />
                                            </StackPanel>
                                            <TextBlock Text="{Binding Description}" FontSize="12" Foreground="{DynamicResource SecondaryTextBrush}" TextTrimming="CharacterEllipsis" MaxHeight="40" />
                                        </StackPanel>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Border>
            </StackPanel>
        </Grid>

        <Frame x:Name="MainFrame"
               Grid.Row="2"
               NavigationUIVisibility="Hidden"/>

        <Button x:Name="ThemeToggleButton"
                Grid.RowSpan="3"
                Width="54"
                Height="54"
                HorizontalAlignment="Right"
                VerticalAlignment="Bottom"
                Margin="0,0,24,24"
                Click="ThemeToggleButton_Click"
                Background="{DynamicResource AccentBrush}"
                Foreground="White"
                BorderThickness="0"
                Cursor="Hand">
            <Button.Template>
                <ControlTemplate TargetType="Button">
                    <Border Background="{TemplateBinding Background}" CornerRadius="27">
                        <Border.Effect>
                            <DropShadowEffect Color="#000000" BlurRadius="12" ShadowDepth="2" Opacity="0.16"/>
                        </Border.Effect>
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                </ControlTemplate>
            </Button.Template>
            <TextBlock x:Name="ThemeToggleIcon" Text="☾" FontSize="20" FontWeight="Bold" Foreground="White"/>
        </Button>
    </Grid>
</Window>
