<Application x:Class="ProjetFilmv1.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             StartupUri="MainWindow.xaml">
    <Application.Resources>
        <SolidColorBrush x:Key="AppBackgroundBrush" Color="#FFF8FC"/>
        <SolidColorBrush x:Key="SurfaceBrush" Color="#FFFFFF"/>
        <SolidColorBrush x:Key="SurfaceAltBrush" Color="#F7F4FF"/>
        <SolidColorBrush x:Key="TextBrush" Color="#18181B"/>
        <SolidColorBrush x:Key="SecondaryTextBrush" Color="#5B6475"/>
        <SolidColorBrush x:Key="AccentBrush" Color="#7D5FFF"/>
        <SolidColorBrush x:Key="AccentSoftBrush" Color="#F1EDFF"/>
        <SolidColorBrush x:Key="BorderBrush" Color="#E5DEFF"/>
        <SolidColorBrush x:Key="NavBackgroundBrush" Color="#141924"/>
        <SolidColorBrush x:Key="InputBorderBrush" Color="#D9D0FF"/>
        <SolidColorBrush x:Key="InputTextBrush" Color="#18181B"/>
    </Application.Resources>
</Application>
