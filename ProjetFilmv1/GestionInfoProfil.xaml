<Page x:Class="ProjetFilmV1.GestionInfoProfile"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Profil" Height="700" Width="1100" Background="White">
    
    <Grid Margin="30">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" HorizontalAlignment="Center" Margin="0,10,0,30">
            <Image Source="/GestionProfile/img/photoprofile.jpg"
                   Width="80" Height="80"
                   Stretch="UniformToFill">
                <Image.Clip>
                    <EllipseGeometry Center="40,40" RadiusX="40" RadiusY="40" />
                </Image.Clip>
            </Image>
            <TextBlock Text="{Binding Username}" FontWeight="Bold" FontSize="18" Margin="0,12,0,0" HorizontalAlignment="Center"/>
            <TextBlock Text="{Binding Email}" Foreground="Gray" HorizontalAlignment="Center" Margin="0,4,0,0"/>
        </StackPanel>

        <StackPanel Grid.Row="1" VerticalAlignment="Top" HorizontalAlignment="Center" Width="450">
            <TextBlock Text="Modifier vos informations" FontWeight="Bold" FontSize="16" Margin="0,0,0,20"/>
            
            <TextBlock Text="Nom d'utilisateur" Margin="0,0,0,5" Foreground="#555"/>
            <TextBox Name="UsernameTextBox" 
                     Text="{Binding Username, UpdateSourceTrigger=PropertyChanged}"
                     Padding="5" Height="35" VerticalContentAlignment="Center" Margin="0,0,0,15"/>
            
            <TextBlock Text="Email" Margin="0,0,0,5" Foreground="#555"/>
            <TextBox Name="EmailTextBox" 
                     Text="{Binding Email, UpdateSourceTrigger=PropertyChanged}"
                     Padding="5" Height="35" VerticalContentAlignment="Center" Margin="0,0,0,15"/>
            
            <TextBlock Text="Nouveau mot de passe (optionnel)" Margin="0,0,0,5" Foreground="#555"/>
            <PasswordBox Name="PasswordInput" 
                         Padding="5" Height="35" VerticalContentAlignment="Center" Margin="0,0,0,20"/>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Enregistrer" Click="BtnEnregistrer_Click" 
                        Width="100" Height="30" Margin="0,0,10,0" 
                        Background="#0078D7" Foreground="White" BorderThickness="0"/>
                <Button Content="Annuler" Click="BtnAnnuler_Click" Width="80" Height="30" />
            </StackPanel>
        </StackPanel>
    </Grid>
</Page>
