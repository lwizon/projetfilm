<Page x:Class="ProjetFilmv1.AuthPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Authentification">
    <Grid Background="White">
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <Grid Margin="28">
                <Border HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Width="Auto"
                        MaxWidth="620"
                        Padding="40"
                        CornerRadius="24"
                        BorderBrush="#DDD6FE"
                        BorderThickness="1"
                        Background="#FCFBFF">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="18" Color="#7D5FFF" Opacity="0.12" ShadowDepth="0"/>
                    </Border.Effect>

                    <StackPanel>
                        <TextBlock x:Name="TitleText"
                                   FontSize="34"
                                   FontWeight="Bold"
                                   Margin="0,0,0,8"/>
                        <TextBlock x:Name="SubtitleText"
                                   Foreground="#6B7280"
                                   FontSize="15"
                                   Margin="0,0,0,26"
                                   TextWrapping="Wrap"/>

                        <StackPanel x:Name="NameSection" Margin="0,0,0,14">
                            <TextBlock Text="Nom" FontSize="15" FontWeight="SemiBold"/>
                            <TextBox x:Name="NomTextBox" Margin="0,8,0,0" MinWidth="260" MinHeight="42" FontSize="15" Padding="10,8"/>
                        </StackPanel>

                        <StackPanel Margin="0,0,0,14">
                            <TextBlock Text="Email" FontSize="15" FontWeight="SemiBold"/>
                            <TextBox x:Name="EmailTextBox" Margin="0,8,0,0" MinWidth="260" MinHeight="42" FontSize="15" Padding="10,8"/>
                        </StackPanel>

                        <StackPanel Margin="0,0,0,22">
                            <TextBlock Text="Mot de passe" FontSize="15" FontWeight="SemiBold"/>
                            <PasswordBox x:Name="PasswordBox" Margin="0,8,0,0" MinWidth="260" MinHeight="42" FontSize="15" Padding="10,8"/>
                        </StackPanel>

                        <Button x:Name="SubmitButton"
                                MinWidth="210"
                                MinHeight="46"
                                HorizontalAlignment="Left"
                                Click="SubmitButton_Click"
                                Background="#7D5FFF"
                                Foreground="White"
                                BorderThickness="0"
                                Padding="20,12"
                                FontSize="15"
                                FontWeight="SemiBold"/>

                        <Border Background="#F1EDFF"
                                CornerRadius="14"
                                Padding="16,12"
                                Margin="0,22,0,0">
                            <WrapPanel>
                                <TextBlock x:Name="TogglePromptText"
                                           VerticalAlignment="Center"
                                           Foreground="#4B5563"
                                           FontSize="14"
                                           Margin="0,0,6,0"/>
                                <Button x:Name="ToggleModeButton"
                                        Click="ToggleModeButton_Click"
                                        Background="Transparent"
                                        BorderThickness="0"
                                        Foreground="#7D5FFF"
                                        FontSize="14"
                                        FontWeight="SemiBold"
                                        Cursor="Hand"
                                        Padding="0"/>
                            </WrapPanel>
                        </Border>
                    </StackPanel>
                </Border>
            </Grid>
        </ScrollViewer>
    </Grid>
</Page>
