<Window x:Class="ProjetFilmv1.MovieDetailsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Details du film"
        Height="780"
        Width="1100"
        MinWidth="860"
        MinHeight="620"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize">
    <Window.Resources>
        <Style x:Key="FavoriteActionButtonStyle" TargetType="Button">
            <Setter Property="Padding" Value="14,10"/>
            <Setter Property="Foreground" Value="{DynamicResource OnDarkTextBrush}"/>
            <Setter Property="Background" Value="{DynamicResource AccentBrush}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ButtonBorder"
                                Background="{TemplateBinding Background}"
                                CornerRadius="14"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Opacity" Value="0.92"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Opacity" Value="0.82"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="ButtonBorder" Property="Opacity" Value="0.55"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>
    <Grid Background="{DynamicResource AppBackgroundBrush}">
        <Border Margin="18" Padding="18" Background="{DynamicResource SurfaceBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="18">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="340"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="300"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Grid.RowSpan="3" Grid.Column="0" CornerRadius="14" ClipToBounds="True" Margin="0,0,22,0" Background="{DynamicResource SurfaceAltBrush}">
                    <Image x:Name="PosterImage" Stretch="UniformToFill"/>
                </Border>

                <StackPanel Grid.Column="1" Grid.Row="0" Margin="0,0,22,12">
                    <TextBlock x:Name="TitleText" FontSize="28" FontWeight="Bold" TextWrapping="Wrap" Foreground="{DynamicResource TextBrush}"/>
                    <TextBlock x:Name="SubtitleText" Margin="0,6,0,0" Foreground="{DynamicResource SecondaryTextBrush}" TextWrapping="Wrap"/>
                    <StackPanel Orientation="Horizontal" Margin="0,18,0,0">
                        <Button x:Name="FavoriteButton"
                                Content="Ajouter aux favoris"
                                MinWidth="210"
                                Click="FavoriteButton_Click"
                                Style="{StaticResource FavoriteActionButtonStyle}"/>
                        <TextBlock x:Name="FavoriteStatusText"
                                   Margin="12,0,0,0"
                                   VerticalAlignment="Center"
                                   Foreground="{DynamicResource SecondaryTextBrush}"
                                   Text="Connectez-vous pour enregistrer ce film."/>
                    </StackPanel>
                </StackPanel>

                <StackPanel Grid.Column="1" Grid.Row="1" Margin="0,0,22,0">
                    <TextBlock Text="Synopsis" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,10" Foreground="{DynamicResource TextBrush}"/>
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <TextBlock x:Name="OverviewText" TextWrapping="Wrap" FontSize="14" LineHeight="22" Foreground="{DynamicResource SecondaryTextBrush}"/>
                    </ScrollViewer>
                </StackPanel>

                <StackPanel Grid.Column="2" Grid.Row="0" Grid.RowSpan="2">
                    <Border Background="{DynamicResource AccentSoftBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="16" Padding="16" Margin="0,0,0,16">
                        <StackPanel>
                            <TextBlock Text="Note" FontSize="18" FontWeight="SemiBold" Foreground="{DynamicResource TextBrush}"/>
                            <TextBlock x:Name="VoteText" FontSize="30" FontWeight="Bold" Margin="0,8,0,0" Foreground="{DynamicResource AccentBrush}"/>
                            <TextBlock x:Name="VoteHintText" Foreground="{DynamicResource SecondaryTextBrush}" Text="Base sur la note TMDB"/>
                        </StackPanel>
                    </Border>

                    <Border Background="{DynamicResource SurfaceAltBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="16" Padding="16">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="260"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <TextBlock 
                                Text="Commentaires" 
                                FontSize="18" 
                                FontWeight="SemiBold" 
                                Margin="0,0,0,10" 
                                Foreground="{DynamicResource TextBrush}"/>
                            

                            <ScrollViewer Height="200"
                                          VerticalScrollBarVisibility="Auto"
                                          Margin="0,0,0,10">
                                <StackPanel x:Name="CommentsPanel"/>
                            </ScrollViewer>
                            <TextBox x:Name="CommentTextBox"
                                     Grid.Row="2"
                                     Height="78"
                                     Margin="0,12,0,10"
                                     TextWrapping="Wrap"
                                     AcceptsReturn="True"
                                     VerticalScrollBarVisibility="Auto"/>
                            <Button x:Name="AddCommentButton"
                                    Grid.Row="3"
                                    Content="Ajouter un commentaire"
                                    HorizontalAlignment="Right"
                                    Padding="12,6"
                                    Background="{DynamicResource AccentBrush}"
                                    Foreground="{DynamicResource OnDarkTextBrush}"
                                    BorderThickness="0"/>
                        </Grid>
                    </Border>
                </StackPanel>

                <StackPanel Grid.Column="1" Grid.ColumnSpan="2" Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
                    <Button x:Name="CloseButton" Content="Fermer" Width="100" Click="CloseButton_Click" Background="{DynamicResource AccentBrush}" Foreground="{DynamicResource OnDarkTextBrush}" BorderThickness="0"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
