<Page x:Class="ProjetFilmv1.MovieDetailsWindow2"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Details du film">
    <Grid Background="{DynamicResource AppBackgroundBrush}">
        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto">
            <Border Padding="17" Background="{DynamicResource SurfaceBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" Margin="20" MinWidth="320">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="280"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Image Grid.Row="1" Grid.Column="0"
                           x:Name="PosterImage"
                           Width="300"
                           Height="450"
                           Stretch="UniformToFill"
                           Margin="0,0,16,0"
                           HorizontalAlignment="Left"
                           VerticalAlignment="Top"/>

                    <StackPanel Grid.Row="0" Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,0,12">
                        <TextBlock x:Name="TitleText" FontSize="26" FontWeight="Bold" TextWrapping="Wrap" VerticalAlignment="Center" Foreground="{DynamicResource TextBrush}"/>
                    </StackPanel>

                    <StackPanel Grid.Row="1" Grid.Column="1" MinWidth="260">
                        <TextBlock x:Name="VoteText" Margin="0,0,0,8" FontWeight="SemiBold" Foreground="{DynamicResource AccentBrush}"/>
                        <ScrollViewer VerticalScrollBarVisibility="Auto" Height="200" Margin="0,0,0,12">
                            <TextBlock x:Name="OverviewText" TextWrapping="Wrap" Foreground="{DynamicResource SecondaryTextBrush}"/>
                        </ScrollViewer>

                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
                            <Button x:Name="CloseButton" Content="Fermer" Width="90" Background="{DynamicResource AccentBrush}" Foreground="{DynamicResource OnDarkTextBrush}" BorderThickness="0"/>
                        </StackPanel>
                    </StackPanel>

                    <StackPanel Grid.Row="1" Grid.Column="2" Margin="16,0,0,0" MinWidth="240">
                        <TextBlock Text="Commentaires" FontWeight="Bold" Margin="0,0,0,8" Foreground="{DynamicResource TextBrush}"/>
                        <ScrollViewer Height="200" VerticalScrollBarVisibility="Auto" Margin="0,0,0,8">
                            <StackPanel x:Name="CommentsPanel"/>
                        </ScrollViewer>

                        <TextBox x:Name="CommentTextBox" Height="70" TextWrapping="Wrap" AcceptsReturn="True" Margin="0,0,0,8"/>
                        <Button x:Name="AddCommentButton" Content="Ajouter un commentaire" HorizontalAlignment="Right" Padding="8,4" Background="{DynamicResource AccentBrush}" Foreground="{DynamicResource OnDarkTextBrush}" BorderThickness="0"/>
                    </StackPanel>
                </Grid>
            </Border>
        </ScrollViewer>
    </Grid>
</Page>
