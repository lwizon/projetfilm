<Page x:Class="ProjetFilmv1.MovieDetailsWindow2"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:primitives="clr-namespace:System.Windows.Controls.Primitives;assembly=PresentationFramework"
      Title="Détails du film">
    
    <Page.Resources>
        <Style x:Key="RoundedBlueButtonStyle" TargetType="Button">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="#FF1E88E5"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="14,8"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="10">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              Margin="2"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#FF1976D2"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="#FF1565C0"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        
        <Style x:Key="FavoriteStarButtonStyle" TargetType="primitives:ToggleButton">
            <Setter Property="Width" Value="42"/>
            <Setter Property="Height" Value="42"/>
            <Setter Property="FontSize" Value="24"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="#FF9E9E9E"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Content" Value="☆"/>
            <Setter Property="ToolTip" Value="Ajouter aux favoris"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="primitives:ToggleButton">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="21">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Foreground" Value="#FFFFC107"/>
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter Property="Content" Value="★"/>
                                <Setter Property="Foreground" Value="#FFFFC107"/>
                                <Setter Property="ToolTip" Value="Retirer des favoris"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Page.Resources>
    
    <Grid Background="#FF1F1F1F">
        <Border Padding="17" Background="White" Margin="20" CornerRadius="20">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="340"/>      <!-- Poster -->
                    <ColumnDefinition Width="*"/>        <!-- Contenu central -->
                    <ColumnDefinition Width="320"/>      <!-- Note + commentaires -->
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>       <!-- Titre + bouton favoris -->
                    <RowDefinition Height="*"/>          <!-- Contenu -->
                </Grid.RowDefinitions>

                <!-- Colonne 0 : poster -->
                <Border Grid.Row="1" Grid.Column="0"
                        Width="340"
                        Height="510"
                        Margin="0,0,16,0"
                        HorizontalAlignment="Left"
                        VerticalAlignment="Top"
                        CornerRadius="16"
                        ClipToBounds="True"
                        Background="#FFEAEAEA">
                    <Image x:Name="PosterImage"
                           Stretch="UniformToFill"/>
                </Border>

                <!-- Ligne 0 : titre + bouton favoris (colonne centrale) -->
                <StackPanel Grid.Row="0" Grid.Column="1"
                            Orientation="Horizontal"
                            VerticalAlignment="Center"
                            Margin="0,0,0,12">
                    <TextBlock x:Name="TitleText"
                               FontSize="26"
                               FontWeight="Bold"
                               TextWrapping="Wrap"
                               VerticalAlignment="Center"/>
                    <primitives:ToggleButton x:Name="FavoriteButton"
                                             Margin="16,0,0,0"
                                             VerticalAlignment="Center"
                                             Style="{StaticResource FavoriteStarButtonStyle}"/>
                </StackPanel>

                <!-- Contenu central (synopsis / vidéo / etc.) -->
                <StackPanel Grid.Row="1" Grid.Column="1">
                    <TextBlock x:Name="VoteText"
                               Margin="0,0,0,8"
                               FontWeight="SemiBold"/>
                    <ScrollViewer VerticalScrollBarVisibility="Auto"
                                  Height="200"
                                  Margin="0,0,0,12">
                        <TextBlock x:Name="OverviewText"
                                   TextWrapping="Wrap"/>
                    </ScrollViewer>

                    <!-- Bouton fermer en bas à droite du centre -->
                    <StackPanel Orientation="Horizontal"
                                HorizontalAlignment="Right"
                                Margin="0,12,0,0">
                        <Button x:Name="CloseButton"
                                Content="Fermer"
                                Width="90"/>
                    </StackPanel>

                <!-- Colonne droite : note circulaire + commentaires -->
               <StackPanel Grid.Row="1" Grid.Column="2" Margin="16,0,0,0">
                    
                   <Border Background="#FFF8F9FB"
                           CornerRadius="18"
                           Padding="16"
                           Margin="0,0,0,16">
                        <StackPanel HorizontalAlignment="Center">
                            <TextBlock Text="Note"
                                FontWeight="Bold"
                                FontSize="16"
                                HorizontalAlignment="Center"
                                Margin="0,0,0,10"/>
                            <Grid Width="150" Height="150">
                                <Ellipse Stroke="#FFE0E0E0"
                                    StrokeThickness="10"/>
                                <Path x:Name="ScoreArc"
                                  Stroke="#FF4CAF50"
                                  StrokeThickness="10"
                                  Fill="Transparent"/>
                                <TextBlock x:Name="CircleScoreText"
                                           Text="0/100"
                                           FontSize="18"
                                           FontWeight="Bold"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"/>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <Border Background="#FFF8F9FB"
                        CornerRadius="18"
                        Padding="16">
                        <StackPanel>
                            <TextBlock Text="Commentaires"
                                       FontWeight="Bold"
                                       FontSize="16"
                                       Margin="0,0,0,10"/>

                            <ScrollViewer Height="200"
                                          VerticalScrollBarVisibility="Auto"
                                          Margin="0,0,0,10">
                                <StackPanel x:Name="CommentsPanel"/>
                            </ScrollViewer>

                            <Border Background="White"
                                    CornerRadius="12"
                                    Padding="6"
                                    Margin="0,0,0,10"
                                    BorderBrush="#FFE3E7EE"
                                    BorderThickness="1">
                                <TextBox x:Name="CommentTextBox"
                                         Height="70"
                                         TextWrapping="Wrap"
                                         AcceptsReturn="True"
                                         BorderThickness="0"
                                         Background="Transparent"/>
                            </Border>

                            <Button x:Name="AddCommentButton"
                                    Content="Ajouter un commentaire"
                                    HorizontalAlignment="Right"
                                    Width="190"
                                    Height="40"
                                    Style="{StaticResource RoundedBlueButtonStyle}"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Page>

<!-- Colonne droite : note circulaire + commentaires -->