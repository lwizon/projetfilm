<Page x:Class="ProjetFilmV1.GestionProfile"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Profil" Height="700" Width="1100" Background="#F5F5F7">
    
    <Page.Resources>
        <Style x:Key="FlatButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#333"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="Padding" Value="15,10"/>
            <Setter Property="Margin" Value="0,2"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
    
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                CornerRadius="5" 
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Left" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>

            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#EBECEF"/>
                    <Setter Property="Foreground" Value="#0078D7"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Page.Resources>

    <Grid>
        <Border Background="#202124" Height="180" VerticalAlignment="Top"/>

        <StackPanel x:Name="MainContent" VerticalAlignment="Top" HorizontalAlignment="Center" Margin="0,40,0,0">
            <TextBlock Text="Mon Compte" FontSize="28" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center" Margin="0,0,0,20"/>
            
            <Border Background="White" CornerRadius="15" Width="400" Padding="30" Margin="0,0,0,40">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="20" Color="Black" Opacity="0.1" ShadowDepth="2"/>
                </Border.Effect>
                
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" HorizontalAlignment="Center" Margin="0,0,0,20">
                        <Border Width="90" Height="90" CornerRadius="45" BorderBrush="#EEE" BorderThickness="2">
                            <Border.Background>
                                <ImageBrush ImageSource="/GestionProfile/img/photoprofile.jpg" Stretch="UniformToFill"/>
                            </Border.Background>
                        </Border>
                        <TextBlock Text="Nom_Utilisateur" FontSize="22" FontWeight="Bold" Margin="0,15,0,5" HorizontalAlignment="Center"/>
                        <Button Content="Modifier le profil" 
                                Width="140" 
                                Background="#202124" 
                                Foreground="White" 
                                Padding="10,5" 
                                Cursor="Hand"
                                Click="OpenProfileDetails">
                            <Button.Resources>
                                <Style TargetType="Border">
                                    <Setter Property="CornerRadius" Value="15"/>
                                </Style>
                            </Button.Resources>
                        </Button>
                    </StackPanel>

                    <Separator Grid.Row="1" Background="#F0F0F0" Margin="0,10"/>

                    <StackPanel Grid.Row="2" Margin="0,10,0,0">
                        <Button Content="⚙  Paramètres" Style="{StaticResource FlatButton}"/>
                        <Button Content="📝  Mes critiques" Style="{StaticResource FlatButton}"/>
                        <Button Content="★  Mes notes" Style="{StaticResource FlatButton}"/>
                        <Button Content="♡  Mes favoris" Style="{StaticResource FlatButton}"/>
                        <Button Content="🏆  Mon Top 10" Style="{StaticResource FlatButton}"/>
                        <Separator Background="#F0F0F0" Margin="0,10"/>
                        <Button Content="⎋  Se déconnecter" Style="{StaticResource FlatButton}" Foreground="#D32F2F"/>
                    </StackPanel>
                </Grid>
            </Border>
        </StackPanel>

        <Frame x:Name="MainFrame" NavigationUIVisibility="Hidden" Background="White" Visibility="Collapsed"/>
    </Grid>
</Page>