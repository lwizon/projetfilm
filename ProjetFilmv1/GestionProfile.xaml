<Page x:Class="ProjetFilmV1.GestionProfile"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Profil"
      Background="{DynamicResource AppBackgroundBrush}">
    <Page.Resources>
        <Style x:Key="FlatButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{DynamicResource TextBrush}"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="Padding" Value="15,10"/>
            <Setter Property="Margin" Value="0,2"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="5" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Left" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{DynamicResource AccentSoftBrush}"/>
                    <Setter Property="Foreground" Value="{DynamicResource AccentBrush}"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Page.Resources>

    <Grid>
        <Border Background="{DynamicResource NavBackgroundBrush}" Height="180" VerticalAlignment="Top"/>

        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
            <StackPanel x:Name="MainContent" VerticalAlignment="Top" HorizontalAlignment="Stretch" Margin="20,40,20,20">
                <TextBlock Text="Mon Compte" FontSize="28" FontWeight="Bold" Foreground="{DynamicResource OnDarkTextBrush}" HorizontalAlignment="Center" Margin="0,0,0,20"/>

                <Border Background="{DynamicResource SurfaceBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="15" Width="Auto" MaxWidth="480" HorizontalAlignment="Center" Padding="30" Margin="0,0,0,40">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="20" Color="#000000" Opacity="0.08" ShadowDepth="2"/>
                    </Border.Effect>

                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <StackPanel Grid.Row="0" HorizontalAlignment="Center" Margin="0,0,0,20">
                            <Border Width="90" Height="90" CornerRadius="45" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="2">
                                <Border.Background>
                                    <ImageBrush ImageSource="/GestionProfile/img/photoprofile.jpg" Stretch="UniformToFill"/>
                                </Border.Background>
                            </Border>
                            <TextBlock x:Name="UserNameText" Text="Nom_Utilisateur" FontSize="22" FontWeight="Bold" Margin="0,15,0,5" HorizontalAlignment="Center" TextWrapping="Wrap" TextAlignment="Center"/>
                            <Button Content="Modifier le profil"
                                    MinWidth="160"
                                    Background="{DynamicResource AccentBrush}"
                                    Foreground="{DynamicResource OnDarkTextBrush}"
                                    Padding="10,5"
                                    BorderThickness="0"
                                    Cursor="Hand"
                                    Click="OpenProfileDetails"/>
                        </StackPanel>

                        <Separator Grid.Row="1" Background="{DynamicResource BorderBrush}" Margin="0,10"/>

                        <StackPanel Grid.Row="2" Margin="0,10,0,0">
                            <Button Content="Parametres" Style="{StaticResource FlatButton}"/>
                            <Button Content="Mes critiques" Style="{StaticResource FlatButton}"/>
                            <Button Content="Mes notes" Style="{StaticResource FlatButton}"/>
                            <Button Content="Mes favoris" Style="{StaticResource FlatButton}"/>
                            <Button Content="Mon Top 10" Style="{StaticResource FlatButton}"/>
                            <Separator Background="{DynamicResource BorderBrush}" Margin="0,10"/>
                            <Button x:Name="LogoutButton" Content="Supprimer le compte" Style="{StaticResource FlatButton}" Foreground="#D32F2F" Click="LogoutButton_Click"/>
                        </StackPanel>
                    </Grid>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <Frame x:Name="MainFrame" NavigationUIVisibility="Hidden" Background="{DynamicResource SurfaceBrush}" Visibility="Collapsed"/>
    </Grid>
</Page>
