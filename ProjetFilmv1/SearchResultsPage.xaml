<Page x:Class="ProjetFilmv1.SearchResultsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Resultats de recherche">
    <Grid Margin="10" Background="{DynamicResource AppBackgroundBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <TextBlock x:Name="QueryText" FontWeight="Bold" FontSize="16" Margin="0,0,0,10" TextWrapping="Wrap" Foreground="{DynamicResource TextBrush}" />

        <ListView x:Name="ResultsList" Grid.Row="1" Margin="0,8,0,0" Background="{DynamicResource SurfaceBrush}" BorderBrush="{DynamicResource BorderBrush}">
            <ListView.ItemTemplate>
                <DataTemplate>
                    <Border Padding="6" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1">
                        <DockPanel>
                            <Image Width="80" Height="120" Source="{Binding PosterFullPath}" Stretch="UniformToFill" Margin="0,0,8,0" />
                            <StackPanel>
                                <TextBlock Text="{Binding Title}" FontWeight="Bold" FontSize="14" TextWrapping="Wrap" Foreground="{DynamicResource TextBrush}" />
                                <TextBlock Text="{Binding Overview}" TextWrapping="Wrap" TextTrimming="CharacterEllipsis" MaxHeight="78" Foreground="{DynamicResource SecondaryTextBrush}" FontSize="12" />
                                <TextBlock Text="{Binding VoteAverage, StringFormat=Note : {0:N1}}" Foreground="{DynamicResource AccentBrush}" FontSize="12" />
                            </StackPanel>
                        </DockPanel>
                    </Border>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>

        <TextBlock x:Name="NoResultsText" Foreground="{DynamicResource SecondaryTextBrush}" Visibility="Collapsed" Grid.Row="1" HorizontalAlignment="Center" VerticalAlignment="Center" />
    </Grid>
</Page>
